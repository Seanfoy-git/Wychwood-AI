---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaBreadcrumb from "../../components/SchemaBreadcrumb.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("frameworks");
  return items.map((x) => ({ params: { slug: x.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("frameworks", slug!);
if (!entry) throw new Error(`Framework not found: ${slug}`);

const { Content } = await entry.render();
const path = `/frameworks/${entry.slug}/`;
---

<BaseLayout
  title={`${entry.data.title} — Wychwood Partners`}
  description={entry.data.description}
  canonicalPath={path}
  ogType="article"
>
  <SchemaBreadcrumb crumbs={[
    { name: "Home", href: "/" },
    { name: "Frameworks", href: "/frameworks/" },
    { name: entry.data.title, href: path },
  ]} />

<main class="shell py-14">

  <!-- Framework Hero -->
  <section class="max-w-3xl pb-12 border-b border-[rgb(var(--border))]">

    <p class="kicker">{entry.data.frameworkName ?? "Framework"}</p>

    <h1 class="mt-4">{entry.data.title}</h1>

    <p class="mt-5 text-lg text-[rgb(var(--text-muted))] leading-relaxed">
      {entry.data.description}
    </p>

  </section>

  <!-- Framework Content -->
  <section class="mt-14 max-w-3xl">

    <article class="prose framework max-w-none">
      <Content />
    </article>

    <div class="mt-14 rounded-xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-8">
      <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text-muted))]">Working through this in your business?</p>
      <p class="mt-3 text-base text-[rgb(var(--text))]">
        If this framework is relevant to a problem you're working on, a short conversation is usually the fastest way to work out whether it applies and how.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="https://calendar.app.google/RRKFf2z6rNDrmzFE8"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center rounded-[var(--radius-lg)] bg-[rgb(var(--brand-anchor))] px-5 py-2.5 text-sm font-medium text-white transition hover:opacity-95"
        >
          Book an intro call
        </a>
        <a
          href="mailto:hello@wychwood-partners.com?subject=Question about {entry.data.title}"
          class="text-sm font-medium text-[rgb(var(--text))] hover:underline"
        >
          Or email a question directly →
        </a>
      </div>
    </div>

    <div class="mt-10">
      <a class="text-sm font-medium text-[rgb(var(--text))] hover:underline" href="/frameworks/">
        ← Back to frameworks
      </a>
    </div>

  </section>

</main>

</BaseLayout>
