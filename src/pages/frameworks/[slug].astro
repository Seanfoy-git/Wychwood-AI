---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntryBySlug } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("frameworks");
  return items.map((x) => ({ params: { slug: x.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntryBySlug("frameworks", slug!);
if (!entry) throw new Error(`Framework not found: ${slug}`);

const { Content } = await entry.render();
const path = `/frameworks/${entry.slug}/`;
---
<BaseLayout
  title={`${entry.data.title} — Wychwood Partners`}
  description={entry.data.description}
  canonicalPath={path}
  ogType="article"
>

  <main class="shell py-20">

    <!-- Framework Hero -->
    <section class="max-w-5xl pb-12 border-b border-[rgb(var(--border))]">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[rgb(var(--text-muted))]">
        {entry.data.frameworkName ?? "Framework"}
      </p>

      <h1 class="mt-4 max-w-4xl text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
        {entry.data.title}
      </h1>

      <p class="mt-5 max-w-3xl text-lg text-[rgb(var(--text-muted))] leading-relaxed">
        {entry.data.description}
      </p>

      <div class="mt-8 max-w-3xl rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface))] p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[rgb(var(--text-muted))]">
          Strategic Note
        </p>

        <p class="mt-3 text-sm leading-7">
          Most AI failures in scaling companies are not model failures. They are operating model failures: conflicting metrics, unclear ownership, unstable source systems, and undefined decision rules.
        </p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-5 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--text-muted))]">
            Key Concept
          </p>
          <h2 class="mt-2 text-lg font-semibold tracking-tight">Operational Context</h2>
          <p class="mt-2 text-sm leading-6 text-[rgb(var(--text-muted))]">
            Define what metrics, entities, and workflows actually mean before trying to automate them.
          </p>
        </div>

        <div class="rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-5 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--text-muted))]">
            Key Concept
          </p>
          <h2 class="mt-2 text-lg font-semibold tracking-tight">AI Gotcha</h2>
          <p class="mt-2 text-sm leading-6 text-[rgb(var(--text-muted))]">
            AI scales confusion when source systems, ownership, and decision rules are still ambiguous.
          </p>
        </div>

        <div class="rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-5 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--text-muted))]">
            Key Concept
          </p>
          <h2 class="mt-2 text-lg font-semibold tracking-tight">Strategic Outcome</h2>
          <p class="mt-2 text-sm leading-6 text-[rgb(var(--text-muted))]">
            Better reporting, cleaner decisions, and an operating model that can actually support automation.
          </p>
        </div>
      </div>
    </section>

    <!-- Framework Content -->
    <section class="mt-20 max-w-4xl">
      <article class="framework-prose prose prose-slate prose-lg max-w-none
        prose-headings:font-semibold
        prose-headings:tracking-tight
        prose-h2:mt-16
        prose-h2:mb-4
        prose-h3:mt-10
        prose-h3:mb-3
      ">
        <Content />
      </article>

      <div class="mt-14">
        <a class="text-sm font-medium text-[rgb(var(--text))] hover:underline" href="/frameworks/">
          ← Back to frameworks
        </a>
      </div>
    </section>

  </main>
<style>
  .framework-prose :global(p) {
    margin-top: 0.55rem;
    margin-bottom: 0.8rem;
    line-height: 1.6;
  }
  .framework-prose :global(h2) + p {
    margin-top: 0.35rem;
  }
  .framework-prose :global(ul) {
    margin: 0.9rem 0 1rem;
    padding-left: 1.1rem;
    list-style: disc;
  }
  .framework-prose :global(li) {
    margin: 0.3rem 0;
    padding: 0;
    border: 0;
    background: transparent;
  }
  .framework-prose :global(ol) {
    margin: 0.9rem 0 1rem;
    padding-left: 1.25rem;
  }

  .framework-prose :global(ol li) {
    margin: 0.45rem 0;
    padding-left: 0.15rem;
  }
  .framework-prose :global(h2) {
    font-size: 1.9rem;
    line-height: 1.15;
    margin-top: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .framework-prose :global(h3) {
    display: block;
    margin-top: 2.2rem;
    margin-bottom: 0.6rem;
    padding: 0.9rem 1rem;
    border: 1px solid rgb(var(--border));
    border-radius: 0.9rem;
    background: rgb(var(--surface-elevated));
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .framework-prose :global(h3 + p) {
    margin-top: 0.5rem;
  }

  .framework-prose :global(h3 + ul),
  .framework-prose :global(h3 + ol) {
    margin-top: 0.6rem;
  }

  .framework-prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.25rem 1.25rem 1.1rem;
    border-left: 3px solid rgb(var(--text));
    background: rgb(var(--surface-elevated));
    border-radius: 0.75rem;
  }

  .framework-prose :global(hr) {
    display: none;
  }
</style>
</BaseLayout>