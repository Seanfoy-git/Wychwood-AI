<BaseLayout
  title={`${entry.data.title} — Wychwood Partners`}
  description={entry.data.description}
  canonicalPath={path}
  ogType="article"
>
  <SchemaArticle
    headline={entry.data.title}
    description={entry.data.description}
    urlPath={path}
    authorName="Wychwood Partners"
  />

  <main class="shell py-20">

    <!-- Framework Hero -->
    <section class="max-w-5xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[rgb(var(--text-muted))]">
        {entry.data.frameworkName ?? "Framework"}
      </p>

      <h1 class="mt-4 max-w-4xl text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
        {entry.data.title}
      </h1>

      <p class="mt-5 max-w-3xl text-lg text-[rgb(var(--text-muted))] leading-relaxed">
        {entry.data.description}
      </p>

      <div class="mt-8 max-w-3xl rounded-2xl border border-[rgb(var(--border))] bg-[rgb(var(--surface))] p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[rgb(var(--text-muted))]">
          Strategic Note
        </p>

        <p class="mt-3 text-sm leading-7">
          Most AI failures in scaling companies are not model failures. They are operating model failures: conflicting metrics, unclear ownership, unstable source systems, and undefined decision rules.
        </p>
      </div>
    </section>

    <!-- Framework Content -->
    <section class="mt-16 max-w-3xl">
      <article class="prose prose-lg max-w-none">
        <Content />
      </article>

      <div class="mt-14">
        <a class="text-sm font-medium text-[rgb(var(--text))] hover:underline" href="/frameworks/">
          ← Back to frameworks
        </a>
      </div>
    </section>

  </main>
</BaseLayout>