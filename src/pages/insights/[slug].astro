---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaArticle from '../../components/SchemaArticle.astro';
import SchemaBreadcrumb from '../../components/SchemaBreadcrumb.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.filter(p => !p.data.draft).map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('insights', slug!);
if (!post) throw new Error(`Insight not found: ${slug}`);

const { Content } = await post.render();
const path = `/insights/${post.slug}/`;
---

<BaseLayout
  title={`${post.data.title} — Wychwood Partners`}
  description={post.data.description}
  canonicalPath={path}
  ogType="article"
>
  <SchemaArticle
    headline={post.data.title}
    description={post.data.description}
    urlPath={path}
    datePublished={post.data.publishDate}
    dateModified={post.data.updatedDate}
    authorName={post.data.author}
  />
  <SchemaBreadcrumb crumbs={[
    { name: "Home", href: "/" },
    { name: "Insights", href: "/insights/" },
    { name: post.data.title, href: path },
  ]} />

  <main class="shell py-14">
    <div class="max-w-3xl">
      <p class="kicker">
        {post.data.publishDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
      </p>
      <h1 class="mt-3">{post.data.title}</h1>
      <p class="mt-4 text-lg text-[rgb(var(--text-muted))]">{post.data.description}</p>

      <article class="prose insight mt-10 max-w-none">
        <Content />
      </article>

      <div class="mt-14 rounded-xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-8">
        <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text-muted))]">Recognise this problem?</p>
        <p class="mt-3 text-base text-[rgb(var(--text))]">
          If this is live in your business right now, a short conversation costs nothing and usually surfaces whether there's something worth working on together.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="https://calendar.app.google/RRKFf2z6rNDrmzFE8"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-[var(--radius-lg)] bg-[rgb(var(--brand-anchor))] px-5 py-2.5 text-sm font-medium text-white transition hover:opacity-95"
          >
            Book an intro call
          </a>
          <a
            href="mailto:hello@wychwood-partners.com?subject=Question about {post.data.title}"
            class="text-sm font-medium text-[rgb(var(--text))] hover:underline"
          >
            Or email a question directly →
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
