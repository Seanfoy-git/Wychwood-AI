---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaArticle from "../../components/SchemaArticle.astro";
import SchemaBreadcrumb from "../../components/SchemaBreadcrumb.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("case-studies");
  return items
    .filter((x) => !x.data.draft)
    .map((x) => ({ params: { slug: x.slug } }));
}

const slug = Astro.params.slug as string;
const entry = await getEntry("case-studies", slug);
if (!entry) throw new Error(`Case study not found: ${slug}`);

const { Content } = await entry.render();
const path = `/case-studies/${entry.slug}/`;

const kicker = `${entry.data.industry ?? "Case study"}${
  entry.data.stage ? ` • ${entry.data.stage}` : ""
}`;

const outcomes = (entry.data.outcomes ?? []) as string[];
const hasOutcomes = outcomes.length > 0;
---

<BaseLayout
  title={`${entry.data.title} — Case Study — Wychwood Partners`}
  description={entry.data.description}
  canonicalPath={path}
  ogType="article"
>
  <SchemaArticle
    headline={entry.data.title}
    description={entry.data.description}
    urlPath={path}
    datePublished={entry.data.publishDate}
    dateModified={entry.data.updatedDate}
    authorName="Wychwood Partners"
  />
  <SchemaBreadcrumb crumbs={[
    { name: "Home", href: "/" },
    { name: "Case Studies", href: "/case-studies/" },
    { name: entry.data.title, href: path },
  ]} />

  <main class="shell py-14">
    <div class="max-w-3xl">
      <p class="kicker">{kicker}</p>

      <h1 class="mt-3">{entry.data.title}</h1>
      <p class="mt-4 text-lg text-[rgb(var(--text-muted))]">
        {entry.data.description}
      </p>

      {hasOutcomes ? (
        <div class="mt-6 card p-6">
          <p class="kicker">Outcomes</p>
          <ul class="mt-2 space-y-1 text-sm text-[rgb(var(--text-muted))]">
            {outcomes.map((o: string) => (
              <li>• {o}</li>
            ))}
          </ul>
        </div>
      ) : null}

      <article class="prose case-study mt-10 max-w-none">
        <Content />
      </article>

      <div class="mt-14 rounded-xl border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))] p-8">
        <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text-muted))]">Dealing with a similar situation?</p>
        <p class="mt-3 text-base text-[rgb(var(--text))]">
          Every situation is different but the underlying patterns are usually familiar. A short conversation is the fastest way to work out whether there's a fit.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="https://calendar.app.google/RRKFf2z6rNDrmzFE8"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-[var(--radius-lg)] bg-[rgb(var(--brand-anchor))] px-5 py-2.5 text-sm font-medium text-white transition hover:opacity-95"
          >
            Book an intro call
          </a>
          <a
            href="mailto:hello@wychwood-partners.com?subject=Question about {entry.data.title}"
            class="text-sm font-medium text-[rgb(var(--text))] hover:underline"
          >
            Or email a question directly →
          </a>
        </div>
      </div>

      <div class="mt-10">
        <a
          class="text-sm font-medium text-[rgb(var(--text))] hover:underline"
          href="/case-studies/"
        >
          ← Back to case studies
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
