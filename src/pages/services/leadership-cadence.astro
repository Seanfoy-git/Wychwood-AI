---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Leadership Cadence Development",
  provider: { "@type": "Organization", name: "Wychwood Partners" },
  description: "Build a leadership rhythm that keeps your team aligned, accountable, and moving fast. Weekly cadence design for growth-stage companies.",
  url: "https://wychwood-partners.com/services/leadership-cadence/",
};
---
<BaseLayout title="Leadership Cadence — Wychwood Partners" description="Build a leadership rhythm that keeps your team aligned, accountable, and moving fast. Weekly cadence design for growth-stage companies.">
  <SchemaOrg schema={serviceSchema} />
  <main class="shell py-14">
    <a
      href="/services/"
      class="inline-flex items-center gap-2 text-sm text-[rgb(var(--text-muted))] hover:text-[rgb(var(--text))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgba(var(--brand-accent),0.55)] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--surface))]"
    >
      ← Back to services
    </a>
    <h1>Leadership cadence</h1>
    <p class="mt-4 max-w-3xl text-[rgb(var(--text-muted))]">
      A weekly execution rhythm that holds under pressure: clear agendas, explicit decisions, and follow-through that is visible. Meetings are not theatre; they are control points.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
      <div class="card p-6">
        <p class="text-sm font-semibold">What it includes</p>
        <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--text-muted))]">
          <li>• A defined weekly executive rhythm with clear purpose and ownership</li>
          <li>• KPI review tied to variance and named corrective action</li>
          <li>• Decision logs that prevent re-litigation</li>
          <li>• Accountability loops that close issues inside the week</li>
        </ul>
      </div>
      <div class="card p-6">
        <p class="text-sm font-semibold">When it’s needed</p>
        <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--text-muted))]">
          <li>• Meetings without decisions</li>
          <li>• Repeated issues</li>
          <li>• Activity is high but progress is unclear</li>
          <li>• No clear follow-through</li>
        </ul>
      </div>
      <div class="card p-6">
        <p class="text-sm font-semibold">Outcomes</p>
        <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--text-muted))]">
          <li>• Decisions that translate into measurable movement</li>
          <li>• Execution that compounds week over week</li>
          <li>• Clear ownership that survives difficult conversations</li>
          <li>• A leadership team that operates as a unit, not a collection of functions</li>
        </ul>
      </div>
    </div>

    <nav aria-label="Related reading" class="mt-16 border-t border-[rgb(var(--border))] pt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[rgb(var(--text-muted))]">Related reading</h2>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a class="text-[rgb(var(--text))] hover:underline" href="/frameworks/leadership-cadence/">Leadership Cadence framework</a></li>
        <li><a class="text-[rgb(var(--text))] hover:underline" href="/insights/founder-bottleneck/">The founder bottleneck</a></li>
        <li><a class="text-[rgb(var(--text))] hover:underline" href="/insights/premature-headcount/">Premature headcount</a></li>
      </ul>
    </nav>

    <div class="mt-12 card p-8">
      <p class="text-lg font-semibold">Want to install a cadence that sticks?</p>
      <p class="mt-2 text-sm text-[rgb(var(--text-muted))]">We’ll implement the rhythm, then stay close enough to ensure it holds when pressure rises. Discipline is built in repetition.</p>
      <a href="/contact" class="mt-5 inline-flex rounded-[var(--radius-lg)] bg-[rgb(var(--brand-anchor))] px-5 py-3 text-sm font-medium text-white transition hover:opacity-95">Book a call</a>
    </div>
  </main>
</BaseLayout>
