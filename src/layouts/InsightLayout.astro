---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout>
  <main class="shell py-14">
    <div class="max-w-3xl">
      {frontmatter?.title && (
        <header class="mb-10">
          <h1>{frontmatter.title}</h1>

          {frontmatter?.description && (
            <p class="mt-4 text-lg text-[rgb(var(--text-muted))]">
              {frontmatter.description}
            </p>
          )}

          {frontmatter?.publishDate && (
            <p class="mt-3 kicker">
              {new Date(frontmatter.publishDate).toLocaleDateString(undefined, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
          )}
        </header>
      )}

      <article class="prose insight max-w-none">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>
